{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "lib": ["ES2022", "dom"],
    "paths": {
      "@services/*": ["src/app/services/*"],
      "@models/*": ["src/app/models/*"],
      "@core/services/auth.service": ["src/app/services/auth/auth.service.ts"],
      "@core/services/confirm-dialog.service": ["src/app/services/confirm-dialog/confirm-dialog.service.ts"],
      "@core/services/duel-socket.service": ["src/app/services/duel-socket/duel-socket.service.ts"],
      "@core/services/http-error.service": ["src/app/services/http-error/http-error.service.ts"],
      "@core/services/notification.service": ["src/app/services/notification/notification.service.ts"],
      "@core/services/data-access/achievements-api.service": ["src/app/services/data-access/achievements/achievements-api.service.ts"],
      "@core/services/data-access/coach-api.service": ["src/app/services/data-access/coach/coach-api.service.ts"],
      "@core/services/data-access/formation-config-api.service": ["src/app/services/data-access/formation-config/formation-config-api.service.ts"],
      "@core/services/data-access/game-sessions-api.service": ["src/app/services/data-access/game-sessions/game-sessions-api.service.ts"],
      "@core/services/data-access/questions-api.service": ["src/app/services/data-access/questions/questions-api.service.ts"],
      "@core/services/data-access/rankings-api.service": ["src/app/services/data-access/rankings/rankings-api.service.ts"],
      "@core/services/data-access/rewards-api.service": ["src/app/services/data-access/rewards/rewards-api.service.ts"],
      "@core/services/data-access/scoring-api.service": ["src/app/services/data-access/scoring/scoring-api.service.ts"],
      "@core/services/data-access/training-api.service": ["src/app/services/data-access/training/training-api.service.ts"],
      "@core/services/data-access/users-api.service": ["src/app/services/data-access/users/users-api.service.ts"],
      "@core/services/*": ["src/app/services/*"],
      "@shared/models/achievement.model": ["src/app/models/achievement/achievement.model.ts"],
      "@shared/models/auth.model": ["src/app/models/auth/auth.model.ts"],
      "@shared/models/coach.model": ["src/app/models/coach/coach.model.ts"],
      "@shared/models/duel.model": ["src/app/models/duel/duel.model.ts"],
      "@shared/models/formation-config.model": ["src/app/models/formation-config/formation-config.model.ts"],
      "@shared/models/game-session.model": ["src/app/models/game-session/game-session.model.ts"],
      "@shared/models/question.model": ["src/app/models/question/question.model.ts"],
      "@shared/models/ranking.model": ["src/app/models/ranking/ranking.model.ts"],
      "@shared/models/reward.model": ["src/app/models/reward/reward.model.ts"],
      "@shared/models/scoring.model": ["src/app/models/scoring/scoring.model.ts"],
      "@shared/models/training.model": ["src/app/models/training/training.model.ts"],
      "@shared/models/user.model": ["src/app/models/user/user.model.ts"],
      "@shared/models/*": ["src/app/models/*"],
      "@models/achievement.model": ["src/app/models/achievement/achievement.model.ts"],
      "@models/auth.model": ["src/app/models/auth/auth.model.ts"],
      "@models/coach.model": ["src/app/models/coach/coach.model.ts"],
      "@models/duel.model": ["src/app/models/duel/duel.model.ts"],
      "@models/formation-config.model": ["src/app/models/formation-config/formation-config.model.ts"],
      "@models/game-session.model": ["src/app/models/game-session/game-session.model.ts"],
      "@models/question.model": ["src/app/models/question/question.model.ts"],
      "@models/ranking.model": ["src/app/models/ranking/ranking.model.ts"],
      "@models/reward.model": ["src/app/models/reward/reward.model.ts"],
      "@models/scoring.model": ["src/app/models/scoring/scoring.model.ts"],
      "@models/training.model": ["src/app/models/training/training.model.ts"],
      "@models/user.model": ["src/app/models/user/user.model.ts"],
      "@shared/models": ["src/app/models/index.ts"],
      "@core/*": ["src/app/core/*"],
      "@shared/*": ["src/app/shared/*"],
      "@features/*": ["src/app/features/*"],
      "@env/*": ["src/environments/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
